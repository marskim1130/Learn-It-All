NODE_ENV=development

API_HOST=127.0.0.1
API_PORT=3001
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001
API_BASE_URL=http://localhost:3001

POSTGRES_DB=ai_chat_dashboard
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_chat_dashboard

# Redis：登录限流与后续队列。留空则使用内存限流（CI 安全）。
REDIS_URL=redis://127.0.0.1:6379
REDIS_PORT=6379

# 聊天模型提供商：echo（默认，CI 安全）或 openai（OpenAI 兼容接口）
CHAT_PROVIDER=echo
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
